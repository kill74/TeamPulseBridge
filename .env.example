# Runtime defaults for local development
PORT=8080

# Security controls
REQUIRE_SECRETS=false
ADMIN_AUTH_ENABLED=false
ADMIN_JWT_ISSUER=teampulse
ADMIN_JWT_AUDIENCE=teampulse-ops
ADMIN_JWT_SECRET=change-me
ADMIN_ALLOW_CIDRS=
TRUSTED_PROXY_CIDRS=

# Queue backend
QUEUE_BACKEND=log
QUEUE_BUFFER=4096
QUEUE_BACKPRESSURE_ENABLED=true
QUEUE_BACKPRESSURE_SOFT_LIMIT_PERCENT=70
QUEUE_BACKPRESSURE_HARD_LIMIT_PERCENT=90
QUEUE_FAILURE_BUDGET_PERCENT=15
QUEUE_FAILURE_BUDGET_WINDOW=100
QUEUE_FAILURE_BUDGET_MIN_SAMPLES=20
QUEUE_THROTTLE_RETRY_AFTER_SEC=5
RATE_LIMIT_ENABLED=true
RATE_LIMIT_RPM=300
ADMIN_RATE_LIMIT_RPM=60
DEDUP_ENABLED=true
DEDUP_TTL_SEC=300
PUBSUB_PROJECT_ID=
PUBSUB_TOPIC_ID=
FAILED_EVENT_STORE_ENABLED=true
FAILED_EVENT_STORE_PATH=data/failed-events.jsonl
REPLAY_AUDIT_ENABLED=true
REPLAY_AUDIT_PATH=data/replay-audit.jsonl

# Webhook secret placeholders
SLACK_SIGNING_SECRET=
GITHUB_WEBHOOK_SECRET=
GITLAB_WEBHOOK_TOKEN=
TEAMS_CLIENT_STATE=

# Observability
ENVIRONMENT=local
OTEL_EXPORTER_OTLP_ENDPOINT=

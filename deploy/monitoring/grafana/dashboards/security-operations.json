    {
      "type": "timeseries",
      "title": "Security Reject Ratio (5m, 1h, 6h)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "teampulse:security_rejections_ratio:5m", "legendFormat": "5m" },
        { "expr": "teampulse:security_rejections_ratio:1h", "legendFormat": "1h" },
        { "expr": "teampulse:security_rejections_ratio:6h", "legendFormat": "6h" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 }
    },
    {
      "type": "timeseries",
      "title": "Security Rejection Budget Burn (5m, 1h, 6h)",

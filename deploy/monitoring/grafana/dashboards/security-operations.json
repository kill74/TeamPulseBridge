      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "showUnfilled": true
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 14 }
    },
    {
      "type": "state-timeline",
      "title": "Security Alert Timeline",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "max(ALERTS{alertstate=\"firing\",service=\"ingestion-gateway\",alertname=~\"IngestionGatewaySecurity.*|IngestionGatewayPotentialAdminAbuse\"}) by (alertname)",
          "legendFormat": "{{alertname}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colWidth": 0.9,
        "mergeValues": true,
        "rowHeight": 0.9,
        "showValue": "never"
      },
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 22 }
    },
    {
      "type": "timeseries",
      "title": "Security Rejections / sec by Reason",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "topk(5, sum(rate(security_rejections_total[5m])) by (reason))",
          "legendFormat": "{{reason}}"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 29 }
    },
    {
      "type": "timeseries",
      "title": "Security Rejections / sec by Status",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(security_rejections_total[5m])) by (status)",

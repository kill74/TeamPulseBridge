      "targets": [
        { "expr": "teampulse:security_rejection_budget_burn:5m", "legendFormat": "5m" },
        { "expr": "teampulse:security_rejection_budget_burn:1h", "legendFormat": "1h" },
        { "expr": "teampulse:security_rejection_budget_burn:6h", "legendFormat": "6h" }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 }
    },
    {
      "type": "bargauge",
      "title": "Top Reject Reasons",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "topk(6, sum(increase(security_rejections_total[$__range])) by (reason))",
          "legendFormat": "{{reason}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "showUnfilled": true
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 14 }
    },
    {
      "type": "bargauge",

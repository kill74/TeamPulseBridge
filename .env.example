# Runtime defaults for local development
PORT=8080

# Security controls
REQUIRE_SECRETS=false
ADMIN_AUTH_ENABLED=false
ADMIN_JWT_ISSUER=teampulse
ADMIN_JWT_AUDIENCE=teampulse-ops
ADMIN_JWT_SECRET=change-me

# Queue backend
QUEUE_BACKEND=log
QUEUE_BUFFER=4096
PUBSUB_PROJECT_ID=
PUBSUB_TOPIC_ID=

# Webhook secret placeholders
SLACK_SIGNING_SECRET=
GITHUB_WEBHOOK_SECRET=
GITLAB_WEBHOOK_TOKEN=
TEAMS_CLIENT_STATE=

# Observability
ENVIRONMENT=local
OTEL_EXPORTER_OTLP_ENDPOINT=
